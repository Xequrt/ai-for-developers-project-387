# ==========================================
# Calendar Booking App Configuration
# ==========================================

# Environment: development | production
# In production JWT_SECRET_KEY is required
APP_ENV=development

# JWT Configuration (REQUIRED in production, optional in development)
# Minimum 32 characters recommended for security
JWT_SECRET_KEY=change-me-in-production-min-32-characters-long

# JWT Token Expiration (OPTIONAL, default: 7 days)
JWT_EXPIRE_DAYS=7

# Database URL (OPTIONAL, default: sqlite:///./calendar.db)
# Examples:
#   SQLite: sqlite:///./calendar.db
#   PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./calendar.db

# CORS Origins (OPTIONAL, default: http://localhost:5173)
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
